import Link from "next/link";
import {
  BadgeCheck,
  BarChart3,
  Heart,
  MessageCircle,
  Repeat2,
} from "lucide-react";
import {
  createReplyAction,
  deletePostAction,
  togglePinnedPostAction,
  toggleRepostAction,
  toggleLikeAction,
  updatePostAction,
} from "@/app/xcom-actions";
import type { CommunityPostRecord } from "@/lib/xcom-domain";
import {
  formatCompactNumber,
  formatRelativeTime,
} from "@/lib/xcom-formatters";

type PostCardProps = {
  post: CommunityPostRecord & {
    viewerHasLiked?: boolean;
    viewerHasReposted?: boolean;
  };
  interaction?: {
    communitySlug: string;
    redirectTo: string;
    canInteract: boolean;
    canEdit: boolean;
    canDelete: boolean;
    canPin: boolean;
    isEditing: boolean;
    editHref: string;
  };
};

const publicationLabels = {
  draft: "Draft",
  pending: "X sync pending",
  published: "Synced to X",
  failed: "X sync failed",
} as const;

export const PostCard = ({ post, interaction }: PostCardProps) => {
  return (
    <article className="signal-divider px-4 py-4 transition-colors hover:bg-white/[0.025] last:border-b-0 sm:px-6">
      {post.isPinned ? (
        <div className="mb-3 text-[13px] font-medium text-copy-muted">
          Pinned by community mods
        </div>
      ) : null}

      <div className="flex gap-3">
        <div className="flex size-10 shrink-0 items-center justify-center rounded-full bg-surface-secondary text-sm font-bold text-white">
          {post.author.avatar}
        </div>

        <div className="min-w-0 flex-1">
          <div className="flex flex-wrap items-center gap-x-2 gap-y-1 text-[15px]">
            <span className="font-bold text-white">{post.author.displayName}</span>
            {post.author.verified ? (
              <BadgeCheck className="size-4 fill-accent-secondary text-accent-secondary" />
            ) : null}
            <span className="text-copy-muted">{post.author.handle}</span>
            {post.author.role ? (
              <span className="rounded-full border border-white/10 px-2 py-0.5 text-[11px] font-bold uppercase tracking-[0.16em] text-copy-muted">
                {post.author.role}
              </span>
            ) : null}
            <span className="text-copy-soft">. {formatRelativeTime(post.createdAt)}</span>
          </div>

          {interaction?.isEditing ? (
            <form action={updatePostAction} className="mt-3 grid gap-3">
              <input type="hidden" name="postId" value={post.id} />
              <input
                type="hidden"
                name="communitySlug"
                value={interaction.communitySlug}
              />
              <input type="hidden" name="redirectTo" value={interaction.redirectTo} />
              <textarea
                name="body"
                rows={4}
                defaultValue={post.body}
                className="signal-focus w-full rounded-2xl border border-white/10 bg-transparent px-4 py-3 text-[15px] leading-6 text-white placeholder:text-copy-soft"
              />
              <div className="flex items-center justify-end gap-3">
                <Link
                  href={interaction.redirectTo}
                  className="rounded-full border border-white/10 bg-background px-4 py-2 text-sm font-bold text-white transition hover:bg-white/[0.06]"
                >
                  Cancel
                </Link>
                <button
                  type="submit"
                  className="rounded-full bg-accent-secondary px-4 py-2 text-sm font-bold text-white transition hover:brightness-110"
                >
                  Save
                </button>
              </div>
            </form>
          ) : (
            <div className="mt-1 whitespace-pre-line text-[15px] leading-6 text-slate-100">
              {post.body}
            </div>
          )}

          {post.media ? (
            <div className="mt-3 overflow-hidden rounded-2xl border border-white/10 bg-surface-secondary">
              <div className="px-4 pt-4 text-[11px] font-bold uppercase tracking-[0.22em] text-copy-soft">
                {post.media.kind}
              </div>
              <div className="mt-2 px-4 text-[20px] font-extrabold leading-tight text-white">
                {post.media.title}
              </div>
              <p className="mt-2 max-w-2xl px-4 text-[15px] leading-6 text-copy-muted">
                {post.media.subtitle}
              </p>
              <div className="mt-4 border-t border-white/10 px-4 py-3 text-[12px] font-medium text-copy-muted">
                {post.media.footer}
              </div>
            </div>
          ) : null}

          <div className="mt-3 text-[13px] text-copy-soft">
            {publicationLabels[post.xSyncStatus]}
          </div>
          {post.viewerHasReposted && post.viewerRepostXSyncStatus ? (
            <div className="mt-1 text-[13px] text-copy-soft">
              Your repost: {publicationLabels[post.viewerRepostXSyncStatus]}
            </div>
          ) : null}

          {interaction &&
          (interaction.canEdit || interaction.canDelete || interaction.canPin) ? (
            <div className="mt-3 flex flex-wrap items-center gap-4 text-[11px] font-bold uppercase tracking-[0.16em] text-copy-muted">
              {interaction.canEdit && !interaction.isEditing ? (
                <Link href={interaction.editHref} className="transition hover:text-white">
                  Edit
                </Link>
              ) : null}
              {interaction.canPin ? (
                <form action={togglePinnedPostAction}>
                  <input type="hidden" name="postId" value={post.id} />
                  <input
                    type="hidden"
                    name="communitySlug"
                    value={interaction.communitySlug}
                  />
                  <input
                    type="hidden"
                    name="redirectTo"
                    value={interaction.redirectTo}
                  />
                  <button type="submit" className="transition hover:text-white">
                    {post.isPinned ? "Unpin" : "Pin"}
                  </button>
                </form>
              ) : null}
              {interaction.canDelete ? (
                <form action={deletePostAction}>
                  <input type="hidden" name="postId" value={post.id} />
                  <input
                    type="hidden"
                    name="communitySlug"
                    value={interaction.communitySlug}
                  />
                  <input
                    type="hidden"
                    name="redirectTo"
                    value={interaction.redirectTo}
                  />
                  <button type="submit" className="transition hover:text-white">
                    Delete
                  </button>
                </form>
              ) : null}
            </div>
          ) : null}

          <div className="mt-3 flex max-w-[460px] items-center justify-between text-[13px] text-copy-muted">
            <div className="-ml-2 flex min-w-[58px] items-center gap-2 rounded-full px-2 py-2 transition hover:bg-accent-secondary/10 hover:text-accent-secondary">
              <MessageCircle className="size-4" />
              <span>{formatCompactNumber(post.metrics.replies)}</span>
            </div>
            {interaction?.canInteract ? (
              <form action={toggleRepostAction}>
                <input type="hidden" name="postId" value={post.id} />
                <input
                  type="hidden"
                  name="communitySlug"
                  value={interaction.communitySlug}
                />
                <input type="hidden" name="redirectTo" value={interaction.redirectTo} />
                <button
                  type="submit"
                  className={`-ml-2 flex min-w-[58px] items-center gap-2 rounded-full px-2 py-2 transition ${
                    post.viewerHasReposted
                      ? "bg-accent-tertiary/10 text-accent-tertiary"
                      : "text-copy-muted hover:bg-accent-tertiary/10 hover:text-accent-tertiary"
                  }`}
                >
                  <Repeat2 className="size-4" />
                  <span>{formatCompactNumber(post.metrics.reposts)}</span>
                </button>
              </form>
            ) : (
              <div className="-ml-2 flex min-w-[58px] items-center gap-2 rounded-full px-2 py-2">
                <Repeat2 className="size-4" />
                <span>{formatCompactNumber(post.metrics.reposts)}</span>
              </div>
            )}
            {interaction?.canInteract ? (
              <form action={toggleLikeAction}>
                <input type="hidden" name="postId" value={post.id} />
                <input
                  type="hidden"
                  name="communitySlug"
                  value={interaction.communitySlug}
                />
                <input type="hidden" name="redirectTo" value={interaction.redirectTo} />
                <button
                  type="submit"
                  className={`-ml-2 flex min-w-[58px] items-center gap-2 rounded-full px-2 py-2 transition ${
                    post.viewerHasLiked
                      ? "bg-accent-primary/10 text-accent-primary"
                      : "text-copy-muted hover:bg-accent-primary/10 hover:text-accent-primary"
                  }`}
                >
                  <Heart className="size-4" />
                  <span>{formatCompactNumber(post.metrics.likes)}</span>
                </button>
              </form>
            ) : (
              <div className="-ml-2 flex min-w-[58px] items-center gap-2 rounded-full px-2 py-2">
                <Heart className="size-4" />
                <span>{formatCompactNumber(post.metrics.likes)}</span>
              </div>
            )}
            <div className="-ml-2 flex min-w-[58px] items-center gap-2 rounded-full px-2 py-2 transition hover:bg-accent-secondary/10 hover:text-accent-secondary">
              <BarChart3 className="size-4" />
              <span>{formatCompactNumber(post.metrics.views)}</span>
            </div>
          </div>

          {post.replies.length ? (
            <div className="mt-4 border-t border-white/10 pt-4">
              <div className="ml-4 border-l border-white/10 pl-4">
                <div className="space-y-3">
                  {post.replies.map((reply) => (
                    <div key={reply.id} className="flex gap-3">
                      <div className="flex size-8 shrink-0 items-center justify-center rounded-full bg-surface-secondary text-xs font-bold text-white">
                        {reply.author.avatar}
                      </div>
                      <div className="min-w-0 flex-1 rounded-2xl bg-surface-secondary px-3 py-3">
                        <div className="flex flex-wrap items-center gap-x-2 gap-y-1">
                          <span className="text-sm font-bold text-white">
                            {reply.author.displayName}
                          </span>
                          {reply.author.verified ? (
                            <BadgeCheck className="size-4 fill-accent-secondary text-accent-secondary" />
                          ) : null}
                          <span className="text-xs text-copy-muted">
                            {reply.author.handle}
                          </span>
                          <span className="text-xs text-copy-soft">
                            {formatRelativeTime(reply.createdAt)}
                          </span>
                        </div>
                        <div className="mt-2 whitespace-pre-line text-sm leading-6 text-slate-100">
                          {reply.body}
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          ) : null}

          {interaction?.canInteract && !interaction.isEditing ? (
            <form
              action={createReplyAction}
              className="mt-4 grid gap-3 border-t border-white/10 pt-4"
            >
              <input type="hidden" name="postId" value={post.id} />
              <input
                type="hidden"
                name="communitySlug"
                value={interaction.communitySlug}
              />
              <input type="hidden" name="redirectTo" value={interaction.redirectTo} />
              <textarea
                name="body"
                rows={2}
                className="signal-focus w-full rounded-2xl border border-white/10 bg-transparent px-4 py-3 text-sm leading-6 text-white placeholder:text-copy-soft"
                placeholder="Reply to this post..."
              />
              <div className="flex justify-end">
                <button
                  type="submit"
                  className="rounded-full border border-white/10 bg-background px-4 py-2 text-sm font-bold text-white transition hover:bg-white/[0.06]"
                >
                  Reply
                </button>
              </div>
            </form>
          ) : null}
        </div>
      </div>
    </article>
  );
};
