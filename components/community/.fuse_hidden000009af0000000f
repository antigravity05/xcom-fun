import Link from "next/link";
import { ChevronLeft } from "lucide-react";
import { joinCommunityAction, leaveCommunityAction } from "@/app/xcom-actions";
import type {
  CommunityRecord,
  CommunityTab,
  MembershipStatus,
} from "@/lib/xcom-domain";
import { communityTabs } from "@/lib/xcom-domain";
import {
  formatCompactNumber,
  shortenContractAddress,
} from "@/lib/xcom-formatters";

type CommunityHeaderProps = {
  community: CommunityRecord;
  activeTab: CommunityTab;
  hasViewer: boolean;
  viewerMembershipStatus: MembershipStatus | null;
  canLeaveCommunity: boolean;
};

export const CommunityHeader = ({
  community,
  activeTab,
  hasViewer,
  viewerMembershipStatus,
  canLeaveCommunity,
}: CommunityHeaderProps) => {
  const secondaryLine = community.contractAddress
    ? shortenContractAddress(community.contractAddress)
    : community.tagline;

  return (
    <section className="border-b border-white/10">
      <div className="sticky top-0 z-20 flex min-h-[53px] items-center gap-4 border-b border-white/10 bg-background/80 px-4 py-2.5 backdrop-blur sm:px-6">
        <Link
          href="/"
          className="inline-flex size-9 items-center justify-center rounded-full text-white transition hover:bg-white/[0.06]"
        >
          <ChevronLeft className="size-5" />
        </Link>
        <div className="min-w-0">
          <div className="truncate text-xl font-extrabold text-white">
            {community.name}
          </div>
          <div className="truncate text-[13px] text-copy-muted">
            {formatCompactNumber(community.memberCount)} members
          </div>
        </div>
      </div>

      <div
        className="relative h-48 sm:h-[200px]"
        style={
          community.bannerUrl
            ? {
                backgroundImage: `linear-gradient(180deg, rgba(0, 0, 0, 0.04), rgba(0, 0, 0, 0.18)), url(${community.bannerUrl})`,
                backgroundPosition: "center",
                backgroundSize: "cover",
              }
            : {
                background: `linear-gradient(135deg, ${community.coverFrom}, ${community.coverTo})`,
              }
        }
      >
        <div className="absolute inset-0 bg-linear-to-t from-background via-transparent to-transparent" />
      </div>

      <div className="relative px-4 pb-0 sm:px-6">
        <div
          className="absolute -top-16 flex size-24 items-center justify-center rounded-full border-4 border-background text-2xl font-bold text-white shadow-[0_0_0_1px_rgba(47,51,54,1)] sm:size-32 sm:text-3xl"
          style={{
            background: `linear-gradient(135deg, ${community.coverTo}, ${community.accentColor})`,
          }}
        >
          {community.avatar}
        </div>

        <div className="flex justify-end pt-3">
          {viewerMembershipStatus === "active" ? (
            canLeaveCommunity ? (
              <form action={leaveCommunityAction}>
                <input type="hidden" name="communitySlug" value={community.slug} />
                <input
                  type="hidden"
                  name="redirectTo"
                  value={`/communities/${community.slug}`}
                />
                <button
                  type="submit"
                  className="rounded-full border border-white/15 bg-background px-4 py-2 text-[15px] font-bold text-white transition hover:bg-white/[0.06]"
                >
                  Leave
                </button>
              </form>
            ) : (
              <div className="rounded-full border border-white/15 bg-background px-4 py-2 text-[15px] font-bold text-white">
                Joined
              </div>
            )
          ) : viewerMembershipStatus === "pending" ? (
            <div className="rounded-full border border-white/15 bg-background px-4 py-2 text-[15px] font-bold text-white">
              Pending
            </div>
          ) : hasViewer ? (
            <form action={joinCommunityAction}>
              <input type="hidden" name="communitySlug" value={community.slug} />
              <input
                type="hidden"
                name="redirectTo"
                value={`/communities/${community.slug}`}
              />
              <button
                type="submit"
                className="rounded-full bg-white px-4 py-2 text-[15px] font-bold text-black transition hover:bg-white/90"
              >
                Join
              </button>
            </form>
          ) : (
            <Link
              href={`/connect-x?redirectTo=${encodeURIComponent(`/communities/${community.slug}`)}`}
              className="rounded-full bg-white px-4 py-2 text-[15px] font-bold text-black transition hover:bg-white/90"
            >
              Connect X
            </Link>
          )}
        </div>

        <div className="mt-6 sm:mt-8">
          <div className="pt-2">
            <h1 className="text-[31px] leading-tight font-extrabold text-white">
              {community.name}
            </h1>
            {secondaryLine ? (
              <div className="mt-2 text-[15px] text-copy-muted">{secondaryLine}</div>
            ) : null}
            <div className="mt-3 flex flex-wrap items-center gap-4 text-[15px] text-copy-muted">
              <span>
                <span className="font-bold text-white">
                  {formatCompactNumber(community.memberCount)}
                </span>{" "}
                members
              </span>
            </div>
          </div>
        </div>

        <div className="sticky top-[53px] z-10 mt-4 grid grid-cols-5 border-t border-white/10 bg-background/92 backdrop-blur">
          {communityTabs.map((tab) => {
            const isActive = tab.id === activeTab;

            return (
              <Link
                key={tab.id}
                href={`/communities/${community.slug}?tab=${tab.id}`}
                className={`relative flex items-center justify-center px-2 py-[15px] text-[15px] font-medium transition ${
                  isActive
                    ? "text-white"
                    : "text-copy-muted hover:bg-white/[0.03] hover:text-white"
                }`}
              >
                <span>{tab.label}</span>
                {isActive ? (
                  <span className="absolute bottom-0 h-1 w-14 rounded-full bg-accent-secondary" />
                ) : null}
              </Link>
            );
          })}
        </div>
      </div>
    </section>
  );
};
