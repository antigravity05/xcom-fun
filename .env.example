# ─── Database (Neon / Supabase / any PostgreSQL) ───
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── Twitter/X OAuth 2.0 ───
# Get these from https://developer.x.com/en/portal/dashboard
X_CLIENT_ID=
X_CLIENT_SECRET=
X_CALLBACK_URL=https://xcom.fun/api/auth/x/callback

# ─── Token encryption ───
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# ─── App URL (used for redirects) ───
NEXT_PUBLIC_APP_URL=https://xcom.fun
