# ─── Database (Neon / Supabase / any PostgreSQL) ───
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── Zernio (recommended — $19/mo, handles OAuth for you) ───
# Sign up at https://zernio.com/signup
# Create a profile, then grab your API key and profile ID.
ZERNIO_API_KEY=sk_...
ZERNIO_PROFILE_ID=prof_...

# ─── Twitter/X OAuth 2.0 (legacy — only if NOT using Zernio) ───
# Get these from https://developer.x.com/en/portal/dashboard
# X_CLIENT_ID=
# X_CLIENT_SECRET=
# X_CALLBACK_URL=https://x-com.fun/api/auth/x/callback

# ─── Token encryption ───
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# ─── App URL (used for redirects) ───
NEXT_PUBLIC_BASE_URL=https://x-com.fun
