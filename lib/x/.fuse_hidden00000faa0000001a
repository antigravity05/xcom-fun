import "server-only";

import { readFile } from "node:fs/promises";
import { join } from "node:path";
import type { PublicationStatus } from "@/lib/xcom-domain";
import { postTweet, XAPIError } from "@/lib/x/x-api-client";
import { refreshAccessToken } from "@/lib/x/oauth-client";
import { decryptToken, encryptToken } from "@/lib/x/token-encryption";

export type XPublicationIntent = {
  localPostId: string;
  xAccountUserId: string;
  body: string;
};

export type XPublicationResult = {
  status: PublicationStatus;
  externalPostId?: string;
  errorMessage?: string;
};

const getUserTokens = async (userId: string) => {
  try {
    const tokenPath = join(process.cwd(), "data", "user-tokens", `${userId}.json`);
    const content = await readFile(tokenPath, "utf8");
    return JSON.parse(content) as {
      userId: string;
      xUserId: string;
      xHandle: string;
      displayName: string;
      avatar: string;
      accessToken: string;
      refreshToken: string | null;
      tokenExpiresAt: string;
    };
  } catch {
    return null;
  }
};

const saveUserTokens = async (
  userId: string,
  tokens: {
    userId: string;
    xUserId: string;
    xHandle: string;
    displayName: string;
    avatar: string;
    accessToken: string;
    refreshToken: string | null;
    tokenExpiresAt: string;
  }
) => {
  const { mkdir, writeFile } = await import("node:fs/promises");
  const tokenPath = join(process.cwd(), "data", "user-tokens");
  await mkdir(tokenPath, { recursive: true });
  await writeFile(
    join(tokenPath, `${userId}.json`),
    JSON.stringify(tokens, null, 2),
    "utf8"
  );
};

export const queueXPublication = async (
  intent: XPublicationIntent,
): Promise<XPublicationResult> => {
  try {
    const storedTokens = await getUserTokens(intent.xAccountUserId);

    if (!storedTokens) {
      return {
        status: "failed",
        errorMessage: "No OAuth tokens found for user",
      };
    }

    let accessToken = decryptToken(storedTokens.accessToken);
    let refreshToken = storedTokens.refreshToken
      ? decryptToken(storedTokens.refreshToken)
      : null;

    const expiresAt = new Date(storedTokens.tokenExpiresAt);
    const now = new Date();

    if (now > expiresAt && refreshToken) {
      try {
        const refreshedTokens = await refreshAccessToken(refreshToken);
        accessToken = refreshedTokens.access_token;
        refreshToken = refreshedTokens.refresh_token ?? refreshToken;

        const encryptedAccessToken = encryptToken(accessToken);
        const encryptedRefreshToken = refreshToken ? encryptToken(refreshToken) : null;

        await saveUserTokens(intent.xAccountUserId, {
          ...storedTokens,
          accessToken: encryptedAccessToken,
          refreshToken: encryptedRefreshToken,
          tokenExpiresAt: new Date(
            Date.now() + refreshedTokens.expires_in * 1000
          ).toISOString(),
        });
      } catch (error) {
        console.error("Token refresh failed:", error);
        return {
          status: "failed",
          errorMessage: "Failed to refresh access token",
        };
      }
    }

    const result = await postTweet(accessToken, intent.body);

    return {
      status: "published",
      externalPostId: result.id,
    };
  } catch (error) {
    if (error instanceof XAPIError) {
      if (error.statusCode === 401) {
        return {
          status: "failed",
          errorMessage: "Unauthorized - access token expired or invalid",
        };
      }

      if (error.statusCode === 403) {
        return {
          status: "failed",
          errorMessage: "Forbidden - insufficient permissions",
        };
      }

      if (error.statusCode === 429) {
        return {
          status: "failed",
          errorMessage: "Rate limited - please try again later",
        };
      }
    }

    console.error("Publication error:", error);
    return {
      status: "failed",
      errorMessage: error instanceof Error ? error.message : "Unknown error",
    };
  }
};
